# Ghostty - Contraste óptimo para queratocono (sin halo/dispersión)
background = #0d0d0d
foreground = #e8e8e8

# Selection - contraste moderado
selection-background = #e8e8e8
selection-foreground = #0d0d0d

# Cursor
cursor-style = block

# Font
font-family = JetBrains Mono Nerd Font
font-size = 13

# Window
window-padding-x = 10
window-padding-y = 10

# Auto-start tmux - cada terminal = sesión nueva independiente
command = /usr/bin/tmux

# Keybindings estilo nvim (which-key style)
# Tabs: Alt+1-9 para ir directo, Ctrl+Shift+T nueva, Ctrl+Shift+W cerrar
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_tab:this
keybind = alt+shift+h=previous_tab
keybind = alt+shift+l=next_tab

# Splits
keybind = ctrl+shift+o=new_split:right
keybind = ctrl+shift+e=new_split:down

# Navegación
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:down
keybind = ctrl+k=goto_split:up
keybind = ctrl+l=goto_split:right
