# ================================
# SSH Terminal Connections - TEMPLATE
# ================================
# Copy this file to .env and fill in your values.
# Each connection uses: connection_{N}_ where N is a number.
# All fields with the same number belong to the same connection.
#
# Required:
#   connection_{N}_name=display name
#   connection_{N}_host=ip or domain
#   connection_{N}_user=username
#
# Auth (one of):
#   connection_{N}_key=~/.ssh/key.pem
#   connection_{N}_password=secret
#
# Optional:
#   connection_{N}_port=22
#   connection_{N}_path=/remote/path  (cd to this path on connect)
#   connection_{N}_env_{VAR}=value    (exported in remote shell)

# --- Connection 1 ---
connection_1_name=my-server
connection_1_host=192.168.1.100
connection_1_user=admin
connection_1_key=~/.ssh/id_rsa
# connection_1_password=mypassword
# connection_1_port=2222
# connection_1_path=/home/admin/app
# connection_1_env_APP_ENV=production
# connection_1_env_DB_HOST=localhost
